# 复制为 .env 后填写。所有变量均可被环境变量覆盖。

# 数据库
DB_PATH=./data/valuation.db

# 服务端
HOST=127.0.0.1
PORT=8000
LOG_LEVEL=INFO

# 时区（用于调度时刻）
TZ=Asia/Shanghai

# 数据源
# AkShare 无需 token
# Tushare Pro（可选）：
TUSHARE_TOKEN=

# 调度开关（M1 仅启用 A 股）
SCHEDULE_A_ENABLED=true
SCHEDULE_HK_ENABLED=false
SCHEDULE_US_ENABLED=false

# CORS（前端独立端口时启用）
CORS_ALLOW_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
